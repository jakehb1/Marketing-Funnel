# Environment Variables Template for Video Manager Backend

# Node Environment
NODE_ENV=development

# Server
PORT=5000

# Database Configuration - Use DATABASE_URL for Railway
DATABASE_URL=postgres://user:password@localhost:5432/video_manager

# Alternative: Individual DB Config (used if DATABASE_URL not set)
DB_USER=postgres
DB_PASSWORD=postgres
DB_HOST=localhost
DB_PORT=5432
DB_NAME=video_manager

# Frontend Configuration
FRONTEND_URL=http://localhost:3000

# Approval System
CHARLIE_PIN=1234

# Transcription
USE_WHISPER_CLI=false

# Logging
LOG_LEVEL=info
